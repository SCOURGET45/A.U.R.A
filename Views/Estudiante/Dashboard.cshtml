@model Aura.Models.EstudianteDashboardViewModel

@{
    ViewData["Title"] = "Mi Dashboard A.U.R.A.";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Hola, @Model.NombreAlumno <span class="text-muted fs-5">(@Model.Matricula)</span></h2>

        @if (Model.TieneToleranciaActiva)
        {
            <span class="badge bg-info text-dark p-2 fs-6">
                <i class="bi bi-shield-check"></i> Tolerancia Activa
            </span>
        }
    </div>

    <div class="row mb-5">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-muted">Termómetro Global</h5>
                    <h1 class="display-1 fw-bold @(Model.AsistenciaGlobal >= 80 ? "text-success" : "text-danger")">
                        @Model.AsistenciaGlobal%
                    </h1>
                    <p class="card-text small">Asistencia acumulada del cuatrimestre</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-muted">Bolsa de Justificantes</h5>

                    <div class="mt-3">
                        <label>Emisiones (Máx 2)</label>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar bg-primary" role="progressbar"
                                 style="width: @(Model.JustificantesUsados * 50)%">
                                @Model.JustificantesUsados / 2
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label>Días Amparados por Salud (Máx 15)</label>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar bg-warning text-dark" role="progressbar"
                                 style="width: @((Model.DiasAmparados * 100) / 15)%">
                                @Model.DiasAmparados / 15
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mb-3">Semáforo de Unidades Actuales</h4>
    <div class="row">
        @foreach (var materia in Model.MateriasActivas)
        {
            string colorBorde = materia.Semaforo == "Verde" ? "border-success" :
                                materia.Semaforo == "Amarillo" ? "border-warning" : "border-danger";

            string icono = materia.Semaforo == "Verde" ? "bi-check-circle text-success" :
                           materia.Semaforo == "Amarillo" ? "bi-exclamation-triangle text-warning" : "bi-x-octagon text-danger";

            <div class="col-md-4 mb-3">
                <div class="card shadow-sm @colorBorde border-start border-5 h-100">
                    <div class="card-body">
                        <h5 class="card-title">@materia.NombreMateria</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@materia.UnidadActual</h6>

                        <div class="mt-3">
                            <p class="mb-1">
                                <i class="@icono fs-5 align-middle me-2"></i>
                                Estado: <strong>@materia.Semaforo</strong>
                            </p>
                            <p class="mb-1 text-muted small">
                                Faltas permitidas restantes: <strong>@materia.FaltasPermitidasRestantes</strong>
                            </p>
                            <p class="mb-0 text-muted small">
                                Retardos acumulados: @materia.RetardosAcumulados
                                @if (materia.RetardosAcumulados == 2)
                                {
                                    <span class="text-danger">(1 más = Falta)</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
