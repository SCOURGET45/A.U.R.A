@model Aura.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión - A.U.R.A.";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f4f6f9;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            border-radius: 1rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        .brand-section {
            background: linear-gradient(135deg, #0d6efd, #0dcaf0);
            color: white;
            padding: 3rem 2rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="card login-card flex-row">
                <div class="col-md-5 d-none d-md-flex brand-section text-center">
                    <h1 class="display-4 fw-bold"><i class="bi bi-soundwave"></i></h1>
                    <h2 class="fw-bold">A.U.R.A.</h2>
                    <p class="small mt-2 opacity-75">Asistencia Ultrasónica y Registro Académico</p>
                </div>

                <div class="col-md-7 p-5">
                    <h4 class="fw-bold mb-4">Bienvenido al Portal</h4>

                    <form asp-controller="Auth" asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Correo" type="email" class="form-control" id="floatingInput" placeholder="nombre@universidad.edu">
                            <label for="floatingInput">Correo Institucional</label>
                            <span asp-validation-for="Correo" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Contrasena" type="password" class="form-control" id="floatingPassword" placeholder="Contraseña">
                            <label for="floatingPassword">Contraseña</label>
                            <span asp-validation-for="Contrasena" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold">
                                Iniciar Sesión <i class="bi bi-box-arrow-in-right"></i>
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted small">¿Problemas para ingresar? Contacta a Secretaría Académica.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
