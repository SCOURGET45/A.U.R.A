@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <i class="bi bi-shield-lock text-danger" style="font-size: 5rem;"></i>
            <h1 class="display-5 fw-bold mt-3">Acceso Restringido</h1>
            <p class="lead text-muted mt-3">
                Tu cuenta no tiene los permisos necesarios (Rol) para visualizar esta sección del sistema A.U.R.A.
            </p>
            <p class="small text-muted mb-4">
                El intento de acceso ha sido registrado en la bitácora de seguridad.
            </p>

            <a href="javascript:history.back()" class="btn btn-outline-secondary me-2">
                <i class="bi bi-arrow-left"></i> Regresar
            </a>

            <a asp-controller="Auth" asp-action="Logout" class="btn btn-primary">
                Iniciar con otra cuenta
            </a>
        </div>
    </div>
</div>
