@model IEnumerable<Aura.Models.SolicitudVulnerabilidadViewModel>

@{
    ViewData["Title"] = "Bandeja de Vulnerabilidades";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-inbox-fill text-primary"></i> Bandeja de Dictamen de Vulnerabilidades</h2>
        <span class="badge bg-secondary fs-6">@Model.Count() Casos Pendientes</span>
    </div>
    <hr />

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle-fill"></i> @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center text-muted mt-5">
            <i class="bi bi-shield-check display-1"></i>
            <h4 class="mt-3">Todo al día</h4>
            <p>No hay solicitudes de vulnerabilidad pendientes de revisión.</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0 bg-white">
                <thead class="bg-dark text-white">
                    <tr>
                        <th>Fecha</th>
                        <th>Alumno</th>
                        <th>Grupo</th>
                        <th>Categoría</th>
                        <th>Justificación del Tutor</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var peticion in Model)
                    {
                        <tr>
                            <td class="text-muted small">@peticion.FechaPeticion.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="fw-bold">@peticion.NombreAlumno</div>
                                <div class="text-muted small">@peticion.Matricula</div>
                            </td>
                            <td><span class="badge bg-light text-dark border">@peticion.Grupo</span></td>
                            <td>@peticion.CategoriaMotivo</td>
                            <td style="max-width: 300px;">
                                <p class="mb-0 text-truncate" title="@peticion.JustificacionTutor">
                                    @peticion.JustificacionTutor
                                </p>
                            </td>
                            <td class="text-center">
                                <form asp-controller="Director" asp-action="Dictaminar" method="post" class="d-inline">
                                    <input type="hidden" name="idSolicitud" value="@peticion.IdSolicitud" />

                                    <button type="submit" name="decision" value="Aprobado" class="btn btn-sm btn-success me-1" title="Aprobar y otorgar tolerancia">
                                        <i class="bi bi-check-lg"></i> Aprobar
                                    </button>

                                    <button type="submit" name="decision" value="Rechazado" class="btn btn-sm btn-outline-danger" title="Rechazar solicitud">
                                        <i class="bi bi-x-lg"></i> Rechazar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
